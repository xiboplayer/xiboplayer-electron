{
  "name": "@xiboplayer/electron",
  "version": "0.7.17",
  "description": "xiboplayer - Electron Kiosk Wrapper for PWA",
  "main": "src/main.js",
  "author": "Pau Aliagas <linuxnow@gmail.com>",
  "packageManager": "pnpm@10.7.0",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://xiboplayer.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/xibo-players/xiboplayer-electron.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux dir",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:xvfb": "xvfb-run playwright test"
  },
  "dependencies": {
    "@xiboplayer/proxy": "0.7.17",
    "@xiboplayer/pwa": "0.7.17",
    "electron-auto-launch": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "vitest": "latest"
  },
  "build": {
    "appId": "org.xiboplayer.pwa",
    "productName": "xiboplayer",
    "artifactName": "xiboplayer-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist-packages",
      "buildResources": "resources"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "resources/icon.png",
      "executableName": "xiboplayer"
    },
    "rpm": {
      "depends": []
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
