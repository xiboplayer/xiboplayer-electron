# Xiboplayer secrets — sourced by apply.sh
# Copy to secrets.env and fill in your values.
# DO NOT commit secrets.env — it's in .gitignore.
#
# CMS connection
CMS_URL=https://your-cms.example.com
CMS_KEY=your-server-key

# OAuth2 self-authorization (CMS > Administration > Applications > client_credentials)
# Leave empty to skip auto-authorization (display will wait for manual CMS approval)
API_CLIENT_ID=
API_CLIENT_SECRET=
